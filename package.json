{
  "name": "memeloom",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native meme forge on 0G — generate, curate, mint, and share memes with permanent provenance",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "contracts:compile": "cd foundry && forge build",
    "contracts:test": "cd foundry && forge test -vv",
    "contracts:deploy": "cd foundry && forge script script/DeployMemeloom.s.sol --rpc-url https://evmrpc-testnet.0g.ai --broadcast"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.6",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethers": "6.13.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "15.3.9",
    "openai": "^4.78.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.21.55",
    "wagmi": "^2.14.11",
    "zustand": "^5.0.2",
    "@tanstack/react-query": "^5.62.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.3.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
